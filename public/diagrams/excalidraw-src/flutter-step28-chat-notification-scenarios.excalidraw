{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el733","x":50,"y":10,"width":700,"height":35,"text":"채팅 앱 알림 시나리오별 처리","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el734","x":50,"y":60,"width":700,"height":55,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el735","x":55,"y":65,"width":690,"height":45,"text":"같은 채팅방 열려있음  →  알림 표시 안 함, 메시지만 추가","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el734"},{"type":"rectangle","id":"el736","x":50,"y":127,"width":700,"height":55,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el737","x":55,"y":132,"width":690,"height":45,"text":"다른 화면에 있음  →  인앱 배너로 알림 + 바로가기","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el736"},{"type":"rectangle","id":"el738","x":50,"y":194,"width":700,"height":55,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el739","x":55,"y":199,"width":690,"height":45,"text":"백그라운드/종료  →  시스템 알림 → 탭하면 해당 채팅방 이동","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el738"}],"appState":{"viewBackgroundColor":"#1e1e2e"}}