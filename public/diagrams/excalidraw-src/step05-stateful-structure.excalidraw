{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":150,"y":20,"width":450,"height":40,"text":"StatefulWidget 구조","fontSize":28,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"stateful_widget","x":50,"y":120,"width":220,"height":70,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"stateful_widget_label","x":60,"y":125,"width":200,"height":60,"text":"StatefulWidget\n(불변)","fontSize":18,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"stateful_widget","roughness":1,"opacity":100},{"type":"arrow","id":"a1","x":270,"y":155,"width":100,"height":0,"points":[[0,0],[100,0]],"strokeColor":"#e5e5e5","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"text","id":"a1_label","x":275,"y":125,"width":90,"height":20,"text":"createState()\n1회 호출","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"rectangle","id":"state_obj","x":370,"y":120,"width":220,"height":70,"backgroundColor":"#2d1b69","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"state_obj_label","x":380,"y":125,"width":200,"height":60,"text":"State 객체\n(가변)","fontSize":18,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"state_obj","roughness":1,"opacity":100},{"type":"arrow","id":"a2","x":480,"y":190,"width":0,"height":60,"points":[[0,0],[0,60]],"strokeColor":"#e5e5e5","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type"