      "x": 40,
      "y": 96,
      "width": 181.5,
      "height": 21.0,
      "text": "// 1. TypeScript 타입 정의",
      "fontSize": 15,
      "fontFamily": 2,
      "strokeColor": "#e5e5e5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 0,
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "line_3",
      "x": 40,
      "y": 122,
      "width": 132.0,
      "height": 21.0,
      "text": "interface User {",
      "fontSize": 15,
