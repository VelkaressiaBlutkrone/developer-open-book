{"type": "excalidraw", "version": 2, "source": "excalidraw-diagram-skill", "elements": [{"type": "rectangle", "id": "darkbg", "x": -4000, "y": -3000, "width": 10000, "height": 7500, "backgroundColor": "#1e1e2e", "fillStyle": "solid", "strokeColor": "transparent", "strokeWidth": 0, "roughness": 1, "opacity": 100}, {"type": "text", "id": "txt1", "x": 10, "y": 10, "width": 600, "height": 22, "text": "Time Slicing의 동작 방식", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt2", "x": 10, "y": 35, "width": 600, "height": 22, "text": "메인 스레드 타임라인:", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt3", "x": 10, "y": 60, "width": 600, "height": 22, "text": "Synchronous:", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "lbl4", "x": 10, "y": 88, "width": 200, "height": 22, "text": "", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "barbg5", "x": 220, "y": 85, "width": 300, "height": 20, "backgroundColor": "#555555", "fillStyle": "solid", "strokeColor": "#a0a0a0", "strokeWidth": 2, "roughness": 1, "opacity": 100}, {"type": "rectangle", "id": "fill6", "x": 220, "y": 85, "width": 300.0, "height": 20, "backgroundColor": "#1e3a5f", "fillStyle": "solid", "strokeColor": "#4a9eed", "strokeWidth": 2, "roughness": 1, "opacity": 100}, {"type": "text", "id": "desc7", "x": 530, "y": 88, "width": 300, "height": 20, "text": "(한 덩어리)", "fontSize": 12, "strokeColor": "#a0a0a0", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt8", "x": 10, "y": 115, "width": 600, "height": 22, "text": "|←────────── 200ms, 다른 작업 불가 ──────────→|", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt9", "x": 10, "y": 140, "width": 600, "height": 22, "text": "Concurrent (Time Slicing):", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "lbl10", "x": 10, "y": 168, "width": 200, "height": 22, "text": "", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "barbg11", "x": 220, "y": 165, "width": 300, "height": 20, "backgroundColor": "#555555", "fillStyle": "solid", "strokeColor": "#a0a0a0", "strokeWidth": 2, "roughness": 1, "opacity": 100}, {"type": "rectangle", "id": "fill12", "x": 220, "y": 165, "width": 210.0, "height": 20, "backgroundColor": "#1e3a5f", "fillStyle": "solid", "strokeColor": "#4a9eed", "strokeWidth": 2, "roughness": 1, "opacity": 100}, {"type": "text", "id": "desc13", "x": 530, "y": 168, "width": 300, "height": 20, "text": "(잘게 나뉨)", "fontSize": 12, "strokeColor": "#a0a0a0", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt14", "x": 10, "y": 195, "width": 600, "height": 22, "text": "|5ms|쉼|5ms|쉼|5ms|쉼|5ms|쉼|5ms|쉼|5ms|", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "lbl15", "x": 10, "y": 223, "width": 200, "height": 22, "text": "", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "barbg16", "x": 220, "y": 220, "width": 300, "height": 20, "backgroundColor": "#555555", "fillStyle": "solid", "strokeColor": "#a0a0a0", "strokeWidth": 2, "roughness": 1, "opacity": 100}, {"type": "text", "id": "desc17", "x": 530, "y": 223, "width": 300, "height": 20, "text": "= \"쉼\" 구간에서 브라우저가 할 수 있는 일:", "fontSize": 12, "strokeColor": "#a0a0a0", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt18", "x": 10, "y": 250, "width": 600, "height": 22, "text": "· 사용자 키보드 입력 처리", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt19", "x": 10, "y": 275, "width": 600, "height": 22, "text": "· 마우스 클릭 처리", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt20", "x": 10, "y": 300, "width": 600, "height": 22, "text": "· 애니메이션 프레임 처리", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt21", "x": 10, "y": 325, "width": 600, "height": 22, "text": "· 레이아웃 재계산", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt22", "x": 10, "y": 350, "width": 600, "height": 22, "text": "→ 총 렌더링 시간은 약간 더 길어질 수 있지만", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}, {"type": "text", "id": "txt23", "x": 10, "y": 375, "width": 600, "height": 22, "text": "→ 사용자 체감 성능은 훨씬 좋아진다 (UI가 멈추지 않음)", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100}], "appState": {"viewBackgroundColor": "#1e1e2e"}}