      "x": 40,
      "y": 96,
      "width": 148.5,
      "height": 21.0,
      "text": "(리렌더링되어도 같은 함수 참조)",
      "fontSize": 15,
      "fontFamily": 2,
      "strokeColor": "#e5e5e5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 0,
      "roughness": 0,
