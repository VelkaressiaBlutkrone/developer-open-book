      "y": 148,
      "width": 231.0,
      "height": 21.0,
      "text": "→ todos가 변하면 소비자 리렌더링 (예상대로)",
      "fontSize": 15,
      "fontFamily": 2,
      "strokeColor": "#a0a0a0",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 0,
      "roughness": 0,
      "opacity": 100
    },
