{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":150,"y":10,"width":380,"height":30,"text":"Provider의 한계","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"r1","x":40,"y":55,"width":600,"height":35,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":1,"roughness":1,"opacity":100},{"type":"text","id":"r1_t","x":50,"y":60,"width":580,"height":25,"text":"① 같은 타입의 Provider 두 개 동시 제공 어려움","fontSize":14,"strokeColor":"#ef4444","fontFamily":2,"containerId":"r1","roughness":1,"opacity":100},{"type":"rectangle","id":"r2","x":40,"y":100,"width":600,"height":35,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":1,"roughness":1,"opacity":100},{"type":"text","id":"r2_t","x":50,"y":105,"width":580,"height":25,"text":"② context 의존성 → 위젯 트리 밖에서 상태 접근 번거로움","fontSize":14,"strokeColor":"#ef4444","fontFamily":2,"containerId":"r2","roughness":1,"opacity":100},{"type":"rectangle","id":"r3","x":40,"y":145,"width":600,"height":35,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":1,"roughness":1,"opacity":100},{"type":"text","id":"r3_t","x":50,"y":150,"width":580,"height":25,"text":"③ 컴파일 타임 안전성 부족 → 잘못된 타입 접근 시 런타임 오류","fontSize":14,"strokeColor":"#ef4444","fontFamily":2,"containerId":"r3","roughness":1,"opacity":100},{"type":"rectangle","id":"r4","x":40,"y":190,"width":600,"height":35,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":1,"roughness":1,"opacity":100},{"type":"text","id":"r4_t","x":50,"y":195,"width":580,"height":25,"text":"④ 상