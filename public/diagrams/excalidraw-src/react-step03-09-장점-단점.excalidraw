{"type": "excalidraw", "version": 2, "source": "excalidraw-diagram-skill", "elements": [{"type": "rectangle", "id": "darkbg", "x": -4000, "y": -3000, "width": 10000, "height": 7500, "backgroundColor": "#1e1e2e", "fillStyle": "solid", "strokeColor": "transparent", "strokeWidth": 0, "roughness": 1, "opacity": 100}, {"type": "text", "id": "title1", "x": 20, "y": 10, "width": 516, "height": 28, "text": "장점  단점", "fontSize": 20, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "box2", "x": 20, "y": 45, "width": 516.0, "height": 162, "backgroundColor": "#1e3a5f", "fillStyle": "solid", "strokeColor": "#4a9eed", "strokeWidth": 2, "roughness": 1, "opacity": 100, "roundness": {"type": 3}}, {"type": "text", "id": "txt3", "x": 35, "y": 60, "width": 486, "height": 132, "text": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n· 유연한 기술 선택  · 선택 피로 (Choice Fatigue)\n· 가볍고 빠른 시작  · \"Best Practice\"를 스스로 찾아야 함\n· 점진적 도입 가능 (기존 프로젝트에)  · 도구 간 호환성 문제 가능\n· 큰 생태계 = 많은 선택지  · 생태계 변화 속도가 빠름\n· 특정 벤더에 종속되지 않음  · 팀마다 다른 구조 → 온보딩 비용", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100, "containerId": "box2"}], "appState": {"viewBackgroundColor": "#1e1e2e"}}