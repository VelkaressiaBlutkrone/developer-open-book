{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":100,"y":10,"width":480,"height":30,"text":"ValueKey의 rebuild 최적화 효과","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"nokey","x":30,"y":55,"width":300,"height":150,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"nokey_t","x":110,"y":60,"width":150,"height":20,"text":"Key 없음","fontSize":16,"strokeColor":"#ef4444","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"nokey_d","x":50,"y":85,"width":260,"height":110,"text":"[A, B, C] → [NEW, A, B, C]\n\n위치 0: B가 A Element 재사용\n  → A의 State가 B에! (버그)\n\n위치 3: 새 Element 생성","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"withkey","x":370,"y":55,"width":300,"height":150,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"withkey_t","x":440,"y":60,"width":170,"height":20,"text":"ValueKey 있음","fontSize":16,"strokeColor":"#22c55e","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"withkey_d","x":390,"y":85,"width":260,"height":110,"text":"[A(1), B(2), C(3)]\n  → [NEW(4), A(1), B(2), C(3)]\n\nid:1 → id:1 정확히 매칭\n  (State 보존)\n\nid:4: 새 Element 생성","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}