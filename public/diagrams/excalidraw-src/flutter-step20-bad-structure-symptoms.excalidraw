{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el152","x":50,"y":10,"width":700,"height":35,"text":"나쁜 프로젝트 구조의 증상","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el153","x":50,"y":60,"width":700,"height":45,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el154","x":55,"y":65,"width":690,"height":35,"text":"\"이 비즈니스 로직이 어느 파일에 있지?\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el153"},{"type":"rectangle","id":"el155","x":50,"y":117,"width":700,"height":45,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el156","x":55,"y":122,"width":690,"height":35,"text":"\"API 변경 시 수십 개 파일을 수정해야 한다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el155"},{"type":"rectangle","id":"el157","x":50,"y":174,"width":700,"height":45,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el158","x":55,"y":179,"width":690,"height":35,"text":"\"이 위젯을 테스트하려면 서버가 필요하다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el157"},{"type":"rectangle","id":"el159","x":50,"y":231,"width":700,"height":45,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el160","x":55,"y":236,"width":690,"height":35,"text":"\"새 팀원이 코드 구조를 이해하는 데 2주 걸린다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el159"},{"type":"rectangle","id":"el161","x":50,"y":288,"width":700,"height":45,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el162","x":55,"y":293,"width":690,"height":35,"text":"\"기능 하나 추가했더니 다른 기능이 깨졌다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el161"}],"appState":{"viewBackgroundColor":"#1e1e2e"}}