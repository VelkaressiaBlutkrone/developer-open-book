      "opacity": 100
    },
    {
      "type": "text",
      "id": "item_9",
      "x": 40,
      "y": 307,
      "width": 264.0,
      "height": 22.4,
      "text": "3. Context의 리렌더링 문제를 이해해야 한다 ★",
