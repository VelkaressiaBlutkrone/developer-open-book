{"type": "excalidraw", "version": 2, "source": "excalidraw-diagram-skill", "elements": [{"type": "rectangle", "id": "darkbg", "x": -4000, "y": -3000, "width": 10000, "height": 7500, "backgroundColor": "#1e1e2e", "fillStyle": "solid", "strokeColor": "transparent", "strokeWidth": 0, "roughness": 1, "opacity": 100}, {"type": "text", "id": "title1", "x": 20, "y": 10, "width": 558, "height": 28, "text": "우선순위 분류", "fontSize": 20, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "box2", "x": 20, "y": 45, "width": 558.5, "height": 558, "backgroundColor": "#1e3a5f", "fillStyle": "solid", "strokeColor": "#4a9eed", "strokeWidth": 2, "roughness": 1, "opacity": 100, "roundness": {"type": 3}}, {"type": "text", "id": "txt3", "x": 35, "y": 60, "width": 528, "height": 528, "text": "우선순위  트리거  특성\nImmediate  사용자 입력 (타이핑,  즉시 처리\n(긴급)  클릭, 키보드)  중단 불가\nTransition  useTransition으로  중단 가능\n(전환)  래핑된 업데이트  낮은 우선순위\nDefault  일반 setState  보통 우선순위\n(기본)\n시나리오: 검색어 입력 + 검색 결과 렌더링\n// React 18 이전: 모든 업데이트가 같은 우선순위\nconst handleChange = (e) => {\nsetQuery(e.target.value);  // 입력 필드 업데이트\nsetFilteredResults(search(e.target.value));  // 대규모 리스트 필터링\n// 두 업데이트가 같은 렌더링에서 처리\n// 리스트 필터링이 오래 걸리면 입력 필드도 느려짐!\n};\n// React 18: useTransition으로 우선순위 분리\nconst [isPending, startTransition] = useTransition();\nconst handleChange = (e) => {\nsetQuery(e.target.value);  // 긴급: 입력 필드 즉시 반영\nstartTransition(() => {\nsetFilteredResults(search(e.target.value));  // 전환: 나중에 처리 OK\n});\n// 입력 필드는 즉시 반영, 리스트는 여유 있을 때 업데이트\n};", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100, "containerId": "box2"}], "appState": {"viewBackgroundColor": "#1e1e2e"}}