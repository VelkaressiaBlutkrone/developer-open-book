{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":130,"y":10,"width":420,"height":30,"text":"앱 화면 흐름 예시 (쇼핑 앱)","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"home","x":240,"y":55,"width":180,"height":40,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"home_t","x":250,"y":60,"width":160,"height":30,"text":"홈 화면","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"home","roughness":1,"opacity":100},{"type":"arrow","id":"a1","x":330,"y":95,"width":0,"height":25,"points":[[0,0],[0,25]],"strokeColor":"#4a9eed","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"text","id":"a1_label","x":340,"y":100,"width":80,"height":15,"text":"상품 탭","fontSize":11,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"detail","x":240,"y":120,"width":180,"height":40,"backgroundColor":"#2d1b69","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"detail_t","x":250,"y":125,"width":160,"height":30,"text":"상품 상세 화면","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"detail","roughness":1,"opacity":100},{"type":"arrow","id":"a2","x":330,"y":160,"width":0,"height":25,"points":[[0,0],[0,25]],"strokeColor":"#8b5cf6","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"text","id":"a2_label","x":340,"y":165,"width":80,"height":15,"text":"구매하기 탭","fontSize":11,"strokeColor":"#a0a