{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":150,"y":10,"width":380,"height":30,"text":"FormState 메서드 3가지","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"v","x":40,"y":55,"width":600,"height":65,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"v_t","x":50,"y":60,"width":580,"height":55,"text":"validate()\n→ 모든 TextFormField의 validator 실행\n→ 모두 null 반환 시 true, 하나라도 String 반환 시 false","fontSize":13,"strokeColor":"#e5e5e5","fontFamily":2,"containerId":"v","roughness":1,"opacity":100},{"type":"rectangle","id":"s","x":40,"y":130,"width":600,"height":65,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"s_t","x":50,"y":135,"width":580,"height":55,"text":"save()\n→ 모든 TextFormField의 onSaved 콜백 실행\n→ 입력값을 외부 변수에 저장. validate() 통과 후 호출","fontSize":13,"strokeColor":"#e5e5e5","fontFamily":2,"containerId":"s","roughness":1,"opacity":100},{"type":"rectangle","id":"r","x":40,"y":205,"width":600,"height":65,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"r_t","x":50,"y":210,"width":580,"height":55,"text":"reset()\n→ 모든 TextFormField 초기화 (빈 값으로)\n→ 에러 메시지도 함께 초기화","fontSize":13,"strokeColor":"#e5e5e5","fontFamily":2,"containerId":"r","roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}