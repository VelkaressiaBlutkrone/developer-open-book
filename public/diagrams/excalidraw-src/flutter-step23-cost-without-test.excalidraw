{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el331","x":50,"y":10,"width":700,"height":35,"text":"테스트 없는 개발의 비용","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el332","x":50,"y":60,"width":700,"height":45,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el333","x":55,"y":65,"width":690,"height":35,"text":"\"기능 추가하니 기존 기능이 깨졌다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el332"},{"type":"rectangle","id":"el334","x":50,"y":117,"width":700,"height":45,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el335","x":55,"y":122,"width":690,"height":35,"text":"\"변경이 안전한지 앱 전체를 수동 테스트해야 한다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el334"},{"type":"rectangle","id":"el336","x":50,"y":174,"width":700,"height":45,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el337","x":55,"y":179,"width":690,"height":35,"text":"\"리팩토링하고 싶지만 무서워서 못한다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el336"},{"type":"rectangle","id":"el338","x":50,"y":231,"width":700,"height":45,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el339","x":55,"y":236,"width":690,"height":35,"text":"\"버그 수정이 새 버그를 만든다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el338"},{"type":"rectangle","id":"el340","x":50,"y":288,"width":700,"height":45,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el341","x":55,"y":293,"width":690,"height":35,"text":"\"출시 전 QA에 매번 3일 걸린다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el340"}],"appState":{"viewBackgroundColor":"#1e1e2e"}}