{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":100,"y":10,"width":480,"height":30,"text":"뉴스피드 rebuild 최적화 전/후","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"before","x":20,"y":55,"width":310,"height":200,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"before_t","x":110,"y":60,"width":150,"height":20,"text":"최적화 전","fontSize":16,"strokeColor":"#ef4444","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"before_d","x":40,"y":85,"width":280,"height":160,"text":"NewsFeedPage (setState)\n  └ ListView\n      ├ NewsCard (id:1) ← rebuild (불필요)\n      ├ NewsCard (id:2) ← rebuild (불필요)\n      ├ NewsCard (id:3) ← rebuild (탭한 카드)\n      └ NewsCard (id:4) ← rebuild (불필요)\n\n→ 4개 모두 rebuild","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"after","x":370,"y":55,"width":310,"height":200,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"after_t","x":460,"y":60,"width":150,"height":20,"text":"최적화 후","fontSize":16,"strokeColor":"#22c55e","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"after_d","x":390,"y":85,"width":280,"height":160,"text":"NewsFeedPage (StatelessWidget)\n  └ ListView\n      ├ NewsCard(key:1) ← rebuild 없음\n      ├ NewsCard(key:2) ← rebuild 없음\n      ├ NewsCard(key:3) ← 자체 setState\n      └ NewsCard(key:4) ← rebuild 없음\n\n→ 탭한 카드만 rebuild","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}