{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":150,"y":10,"width":380,"height":30,"text":"Gesture Arena 동작 원리","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"s1","x":220,"y":55,"width":260,"height":40,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"s1_t","x":230,"y":60,"width":240,"height":30,"text":"① 포인터 이벤트 발생","fontSize":14,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"s1","roughness":1,"opacity":100},{"type":"arrow","id":"a1","x":350,"y":95,"width":0,"height":20,"points":[[0,0],[0,20]],"strokeColor":"#555555","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"rectangle","id":"s2","x":180,"y":115,"width":340,"height":40,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"s2_t","x":190,"y":120,"width":320,"height":30,"text":"② Hit Test → GestureRecognizer 수집","fontSize":14,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"s2","roughness":1,"opacity":100},{"type":"arrow","id":"a2","x":350,"y":155,"width":0,"height":20,"points":[[0,0],[0,20]],"strokeColor":"#555555","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"rectangle","id":"s3","x":180,"y":175,"width":340,"height":55,"backgroundColor":"#2d1b69","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"s3_t","x":190,"y":180,"width":320,"height":45,"text":"③ Arena에서 경쟁 시작\n각 recognizer가 처리/포기 선언","fontSize":13,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"s3","roughness":1,"opacity":100},{"type":"arrow","id":"a3","x":350,"y":230,"width":0,"height":20,"points":[[0,0],[0,20]],"strokeColor":"#555555","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"rectangle","id":"s4","x":180,"y":250,"width":340,"height":55,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"s4_t","x":190,"y":255,"width":320,"height":45,"text":"④ 승자 결정\n마지막 1개 또는 명시적 승리 선언","fontSize":13,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"s4","roughness":1,"opacity":100},{"type":"arrow","id":"a4","x":350,"y":305,"width":0,"height":20,"points":[[0,0],[0,20]],"strokeColor":"#555555","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"rectangle","id":"s5","x":220,"y":325,"width":260,"height":40,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"s5_t","x":230,"y":330,"width":240,"height":30,"text":"⑤ 승자의 콜백만 호출","fontSize":14,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"s5","roughness":1,"opacity":100},{"type":"text","id":"example","x":50,"y":385,"width":600,"height":50,"text":"실전 예시: ListView 내부의 GestureDetector\n세로 드래그 → ScrollGestureRecognizer 승리  |  수평 드래그 → HorizontalDragRecognizer 승리","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}