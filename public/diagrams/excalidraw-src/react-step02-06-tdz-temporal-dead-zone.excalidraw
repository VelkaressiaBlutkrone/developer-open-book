{"type": "excalidraw", "version": 2, "source": "excalidraw-diagram-skill", "elements": [{"type": "rectangle", "id": "darkbg", "x": -4000, "y": -3000, "width": 10000, "height": 7500, "backgroundColor": "#1e1e2e", "fillStyle": "solid", "strokeColor": "transparent", "strokeWidth": 0, "roughness": 1, "opacity": 100}, {"type": "text", "id": "title1", "x": 20, "y": 10, "width": 669, "height": 28, "text": "#### TDZ (Temporal Dead Zone)", "fontSize": 20, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "box2", "x": 20, "y": 45, "width": 669.0, "height": 294, "backgroundColor": "#1e3a5f", "fillStyle": "solid", "strokeColor": "#4a9eed", "strokeWidth": 2, "roughness": 1, "opacity": 100, "roundness": {"type": 3}}, {"type": "text", "id": "txt3", "x": 35, "y": 60, "width": 639, "height": 264, "text": "```javascript\n// var — 호이스팅 시 undefined로 초기화\nconsole.log(a); // undefined (에러 아님!)\nvar a = 5;\n// let/const — 호이스팅되지만 초기화되지 않음 (TDZ)\nconsole.log(b); // ReferenceError: Cannot access 'b' before initialization\nlet b = 5;\n// TDZ 구간 시각화\n//  TDZ 시작 (선언은 호이스팅됨)\n//  console.log(b);  ← 여기서 접근하면 에러\n//  ...\n//  let b = 5;  ← TDZ 종료, 초기화됨", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100, "containerId": "box2"}], "appState": {"viewBackgroundColor": "#1e1e2e"}}