{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el104","x":50,"y":10,"width":700,"height":35,"text":"애니메이션의 UX 역할","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el105","x":50,"y":60,"width":700,"height":55,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el106","x":55,"y":65,"width":690,"height":45,"text":"① 공간 인지  →  카드 확장 → \"이 화면이 그 카드에서 왔다\"","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el105"},{"type":"rectangle","id":"el107","x":50,"y":127,"width":700,"height":55,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el108","x":55,"y":132,"width":690,"height":45,"text":"② 피드백 제공  →  버튼 눌릴 때 눌리는 느낌 → 동작 확인","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el107"},{"type":"rectangle","id":"el109","x":50,"y":194,"width":700,"height":55,"backgroundColor":"#2d1b69","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el110","x":55,"y":199,"width":690,"height":45,"text":"③ 시선 유도  →  중요한 변경사항을 부드럽게 강조","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el109"},{"type":"rectangle","id":"el111","x":50,"y":261,"width":700,"height":55,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundne