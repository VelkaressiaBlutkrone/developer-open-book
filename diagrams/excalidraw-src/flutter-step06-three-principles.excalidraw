    {"type":"text","id":"p3_l","x":90,"y":228,"width":500,"height":45,"text":"③ Parent sets position\n부모가 자식을 어디에 배치할지 결정한다 (자식은 자신의 위치를 모른다)","fontSize":14,"strokeColor":"#e5e5e5","fontFamily":2,"containerId":"p3","textAlign":"center","verticalAlign":"middle","opacity":100}
