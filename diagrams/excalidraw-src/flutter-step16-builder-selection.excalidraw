{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el8","x":50,"y":10,"width":700,"height":35,"text":"어떤 것을 선택해야 하는가?","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el9","x":50,"y":60,"width":200,"height":50,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el10","x":55,"y":65,"width":190,"height":40,"text":"FutureBuilder","fontSize":18,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el9"},{"type":"text","id":"el11","x":280,"y":60,"width":450,"height":70,"text":"단순 화면, 상태관리 솔루션 불필요\n데이터를 \"그 화면에서만\" 사용\n→ 간단한 프로필 화면, 상세 화면","fontSize":13,"strokeColor":"#4a9eed","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el12","x":50,"y":145,"width":200,"height":50,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el13","x":55,"y":150,"width":190,"height":40,"text":"StreamBuilder","fontSize":18,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el12"},{"type":"text","id":"el14","x":280,"y":145,"width":450,"height":70,"text":"실시간 데이터 구독\n→ 채팅, 타이머, IoT 센서, WebSocket","fontSize":13,"strokeColor":"#22c55e","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el15","x":50,"y":230,"width":200,"height":50,"backgroundColor":"#2d1b69","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el16","x":55,"y":235,"width":190,"height":40,"text":"Provider/Riverpod","fontSize":18,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el15"},{"type":"text","id":"el17","x":280,"y":230,"width":450,"height":70,"text":"여러 화면에서 데이터 공유 필요\n캐싱·재시도·전역 로딩 상태 필요\n→ 쇼핑몰 상품 목록, 알림 등","fontSize":13,"strokeColor":"#8b5cf6","fontFamily":2,"roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}