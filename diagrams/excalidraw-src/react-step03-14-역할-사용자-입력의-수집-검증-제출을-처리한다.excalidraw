{"type": "excalidraw", "version": 2, "source": "excalidraw-diagram-skill", "elements": [{"type": "rectangle", "id": "darkbg", "x": -4000, "y": -3000, "width": 10000, "height": 7500, "backgroundColor": "#1e1e2e", "fillStyle": "solid", "strokeColor": "transparent", "strokeWidth": 0, "roughness": 1, "opacity": 100}, {"type": "text", "id": "title1", "x": 20, "y": 10, "width": 312, "height": 28, "text": "역할: 사용자 입력의 수집, 검증, 제출을 처리한다", "fontSize": 20, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "box2", "x": 20, "y": 45, "width": 312.0, "height": 206, "backgroundColor": "#1e3a5f", "fillStyle": "solid", "strokeColor": "#4a9eed", "strokeWidth": 2, "roughness": 1, "opacity": 100, "roundness": {"type": 3}}, {"type": "text", "id": "txt3", "x": 35, "y": 60, "width": 282, "height": 176, "text": "React Hook Form\n비제어(Uncontrolled) 기반 고성능 폼 라이브러리\n리렌더링 최소화, 간결한 API\n이 로드맵: Step 33\nZod\nTypeScript-first 스키마 검증 라이브러리\nReact Hook Form과 결합하여 타입 안전 폼 구현\n이 로드맵: Step 32", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100, "containerId": "box2"}], "appState": {"viewBackgroundColor": "#1e1e2e"}}