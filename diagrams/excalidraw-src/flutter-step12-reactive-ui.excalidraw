{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":120,"y":10,"width":440,"height":30,"text":"명령형 UI vs Reactive UI (Flutter)","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"left","x":30,"y":55,"width":290,"height":140,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"left_t","x":90,"y":60,"width":180,"height":25,"text":"명령형(Imperative) UI","fontSize":15,"strokeColor":"#ef4444","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"left_d","x":50,"y":90,"width":250,"height":90,"text":"counter++\ntextView.setText(counter)\nbadge.setCount(counter)\n\n← 개발자가 직접 UI 변경\n← 연관 UI도 직접 업데이트","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"right","x":360,"y":55,"width":290,"height":140,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"right_t","x":410,"y":60,"width":200,"height":25,"text":"Reactive UI — Flutter","fontSize":15,"strokeColor":"#22c55e","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"right_d","x":380,"y":90,"width":250,"height":90,"text":"setState(() => counter++)\n\n// Flutter가 관련 위젯을\n// 자동으로 rebuild\n// build()가 항상 최신 상태\n// 반영하는 UI를 반환","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}