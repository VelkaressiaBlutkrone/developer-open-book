      "fillStyle": "solid",
      "strokeWidth": 0,
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "item_2",
      "x": 40,
      "y": 121,
      "width": 354.20000000000005,
      "height": 19.599999999999998,
      "text": "→ React.lazy(코드 분할), use()(데이터), Streaming SSR",
      "fontSize": 14,
      "fontFamily": 2,
      "strokeColor": "#a0a0a0",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 0,
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "item_3",
      "x": 40,
      "y": 147,
      "width": 254.10000000000002,
      "height": 19.599999999999998,
      "text": "→ \"무엇을 기다리는가\"에 관심 없이 fallback만 선언",
