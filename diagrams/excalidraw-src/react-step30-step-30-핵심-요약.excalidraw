      "opacity": 100
    },
    {
      "type": "text",
      "id": "item_4",
      "x": 40,
      "y": 173,
      "width": 292.6,
      "height": 19.599999999999998,
      "text": "→ 내부: Promise를 throw하고 Suspense가 catch",
