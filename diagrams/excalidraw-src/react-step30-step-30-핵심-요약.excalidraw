      "x": 40,
      "y": 91,
      "width": 343.20000000000005,
      "height": 22.4,
      "text": "1. Suspense = \"비동기 작업을 선언적으로 기다리는 메커니즘\"",
      "fontSize": 16,
      "fontFamily": 2,
      "strokeColor": "#f59e0b",
