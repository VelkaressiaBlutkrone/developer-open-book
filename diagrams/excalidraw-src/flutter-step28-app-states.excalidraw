{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el701","x":50,"y":10,"width":700,"height":35,"text":"3가지 앱 상태와 알림 처리","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el702","x":50,"y":60,"width":700,"height":55,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el703","x":55,"y":65,"width":690,"height":45,"text":"Foreground (앱 활성)  →  onMessage로 수신, 직접 UI 표시","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el702"},{"type":"rectangle","id":"el704","x":50,"y":127,"width":700,"height":55,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el705","x":55,"y":132,"width":690,"height":45,"text":"Background (백그라운드)  →  시스템 트레이 표시, onMessageOpenedApp","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el704"},{"type":"rectangle","id":"el706","x":50,"y":194,"width":700,"height":55,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el707","x":55,"y":199,"width":690,"height":45,"text":"Terminated (종료)  →  getInitialMessage()로 확인","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el706"}],"appState":{"viewBackgroundColor":"#1e1e2e"}}