{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":150,"y":10,"width":400,"height":30,"text":"Material Design 시스템 개념 지도","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"root","x":220,"y":50,"width":260,"height":45,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"root_t","x":230,"y":55,"width":240,"height":35,"text":"Material Design 시스템","fontSize":16,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"root","roughness":1,"opacity":100},{"type":"arrow","id":"a1","x":200,"y":95,"width":0,"height":35,"points":[[0,0],[-100,35]],"strokeColor":"#555555","strokeWidth":2,"endArrowhead":null,"roughness":1,"opacity":100},{"type":"arrow","id":"a2","x":350,"y":95,"width":0,"height":35,"points":[[0,0],[0,35]],"strokeColor":"#555555","strokeWidth":2,"endArrowhead":null,"roughness":1,"opacity":100},{"type":"arrow","id":"a3","x":500,"y":95,"width":0,"height":35,"points":[[0,0],[100,35]],"strokeColor":"#555555","strokeWidth":2,"endArrowhead":null,"roughness":1,"opacity":100},{"type":"rectangle","id":"scaffold","x":20,"y":130,"width":180,"height":40,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"scaffold_t","x":30,"y":135,"width":160,"height":30,"text":"Scaffold","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"scaffold","roughness":1,"opacity":100},{"type":"text","id":"scaffold_desc","x":20,"y":175,"width":180,"height":120,"text":"