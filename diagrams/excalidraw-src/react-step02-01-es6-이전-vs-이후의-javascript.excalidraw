{"type": "excalidraw", "version": 2, "source": "excalidraw-diagram-skill", "elements": [{"type": "rectangle", "id": "darkbg", "x": -4000, "y": -3000, "width": 10000, "height": 7500, "backgroundColor": "#1e1e2e", "fillStyle": "solid", "strokeColor": "transparent", "strokeWidth": 0, "roughness": 1, "opacity": 100}, {"type": "text", "id": "title1", "x": 20, "y": 10, "width": 490, "height": 28, "text": "ES6 이전 vs 이후의 JavaScript", "fontSize": 20, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "center", "verticalAlign": "middle", "opacity": 100}, {"type": "rectangle", "id": "box2", "x": 20, "y": 45, "width": 490.5, "height": 206, "backgroundColor": "#1e3a5f", "fillStyle": "solid", "strokeColor": "#4a9eed", "strokeWidth": 2, "roughness": 1, "opacity": 100, "roundness": {"type": 3}}, {"type": "text", "id": "txt3", "x": 35, "y": 60, "width": 460, "height": 176, "text": "ES5 (2009 이전)  ES6+ (2015 이후)\nvar x = 10;  const x = 10;\nfunction add(a, b) { ... }  const add = (a, b) => ...\nvar name = obj.name;  const { name } = obj;\narr.concat([4])  [...arr, 4]\n'Hello ' + name  `Hello ${name}`\nrequire('module')  import module from 'module'\ncallback(function() {})  callback(() => {})", "fontSize": 14, "strokeColor": "#e5e5e5", "fontFamily": 2, "textAlign": "left", "verticalAlign": "middle", "opacity": 100, "containerId": "box2"}], "appState": {"viewBackgroundColor": "#1e1e2e"}}