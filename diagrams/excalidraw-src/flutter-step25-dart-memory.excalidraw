{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el515","x":50,"y":10,"width":700,"height":35,"text":"Dart의 메모리 관리","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el516","x":50,"y":60,"width":700,"height":55,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el517","x":55,"y":65,"width":690,"height":45,"text":"Young Space (New Generation)  →  새로 생성된 객체. Minor GC로 빠르게 수거","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el516"},{"type":"rectangle","id":"el518","x":50,"y":127,"width":700,"height":55,"backgroundColor":"#2d1b69","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el519","x":55,"y":132,"width":690,"height":45,"text":"Old Space (Old Generation)  →  오래 살아남은 객체. Major GC로 수거","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el518"},{"type":"rectangle","id":"el520","x":50,"y":194,"width":700,"height":55,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el521","x":55,"y":199,"width":690,"height":45,"text":"Garbage Collector (GC)  →  참조 없는 객체를 자동 해제","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el520"},{"type":"rectangle","id":"el522","x":50,"y":261,"width":700,"height":55,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el523","x":55,"y":266,"width":690,"height":45,"text":"루트 참조  →  Static 변수, 스택 변수, 글로벌 변수","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el522"}],"appState":{"viewBackgroundColor":"#1e1e2e"}}