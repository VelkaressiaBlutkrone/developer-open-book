{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el398","x":50,"y":10,"width":700,"height":35,"text":"렌더링 성능과 사용자 경험","fontSize":24,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el399","x":50,"y":60,"width":700,"height":55,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el400","x":55,"y":65,"width":690,"height":45,"text":"16ms 이내 프레임 렌더링  →  60fps 유지 → 매끄러운 스크롤","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el399"},{"type":"rectangle","id":"el401","x":50,"y":127,"width":700,"height":55,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el402","x":55,"y":132,"width":690,"height":45,"text":"프레임 드롭 발생  →  스크롤 끊김, 애니메이션 버벅임","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el401"},{"type":"rectangle","id":"el403","x":50,"y":194,"width":700,"height":55,"backgroundColor":"#5c3d1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el404","x":55,"y":199,"width":690,"height":45,"text":"장시간 빌드  →  앱 반응 지연 → 사용자 이탈","fontSize":15,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el403"}],"appState":{"viewBackgroundColor":"#1e1e2e"}}