{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":120,"y":10,"width":460,"height":30,"text":"기본 ThemeData vs AdaptiveTheme","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"left_box","x":30,"y":55,"width":300,"height":170,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"left_title","x":100,"y":60,"width":180,"height":25,"text":"기본 ThemeData의 한계","fontSize":15,"strokeColor":"#ef4444","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"left_items","x":50,"y":90,"width":260,"height":120,"text":"ThemeMode.system\n  → 시스템 설정만 따름\n\nThemeMode.light\n  → 고정 (런타임 변경 불가)\n\n앱 재시작 후 선택 초기화\n  → SharedPreferences 직접 구현 필요","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"right_box","x":370,"y":55,"width":300,"height":170,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"right_title","x":440,"y":60,"width":180,"height":25,"text":"AdaptiveTheme 장점","fontSize":15,"strokeColor":"#22c55e","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"right_items","x":390,"y":90,"width":260,"height":120,"text":"setLight()   → 라이트 전환\nsetDark()    → 다크 전환\nsetSystem()  → 시스템 연동\n\n선택한 테마 자동 저장\n(SharedPreferences 불필요)\n\n앱 재시작 후 이전 선택 복원","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"arrow","id":"arrow","x":330,"y":140,"width":40,"height":0,"points":[[0,0],[40,0]],"strokeColor":"#e5e5e5","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}