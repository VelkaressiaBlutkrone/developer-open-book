      "type": "text",
      "id": "line_11",
      "x": 40,
      "y": 330,
      "width": 165.0,
      "height": 21.0,
      "text": "_.debounce(fn, 300);",
      "fontSize": 15,
      "fontFamily": 2,
      "strokeColor": "#e5e5e5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 0,
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "line_12",
      "x": 40,
      "y": 356,
      "width": 247.5,
      "height": 21.0,
      "text": "// ✅ 개별 import (tree-shakable)",
