      "fillStyle": "solid",
      "strokeWidth": 0,
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "line_10",
      "x": 40,
      "y": 304,
      "width": 338.25,
      "height": 21.0,
      "text": "import _ from 'lodash';   // 70KB 전부 번들에!",
