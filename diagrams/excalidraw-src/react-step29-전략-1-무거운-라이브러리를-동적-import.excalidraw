      "x": 40,
      "y": 174,
      "width": 173.25,
      "height": 21.0,
      "text": "전략 2: 가벼운 대안 라이브러리 사용",
      "fontSize": 15,
      "fontFamily": 2,
      "strokeColor": "#e5e5e5",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 0,
