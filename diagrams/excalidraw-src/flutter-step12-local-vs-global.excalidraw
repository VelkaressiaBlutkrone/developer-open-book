{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"title","x":120,"y":10,"width":440,"height":30,"text":"Local State vs Global State","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"local","x":30,"y":55,"width":300,"height":210,"backgroundColor":"#1e3a5f","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"local_t","x":120,"y":60,"width":140,"height":25,"text":"Local State","fontSize":17,"strokeColor":"#4a9eed","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"local_char","x":50,"y":90,"width":260,"height":60,"text":"• 단일 위젯과 직접 자식만 사용\n• 위젯 제거 시 상태도 사라짐\n• setState()로 관리","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"text","id":"local_ex","x":50,"y":155,"width":260,"height":100,"text":"예시:\n  폼 입력 필드의 현재 값\n  버튼 로딩 상태\n  탭 선택 인덱스\n  애니메이션 진행 상태\n  비밀번호 토글","fontSize":11,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"global","x":370,"y":55,"width":300,"height":210,"backgroundColor":"#2d1b69","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"global_t","x":450,"y":60,"width":150,"height":25,"text":"Global State","fontSize":17,"strokeColor":"#8b5cf6","fontFamily":2,"textAlign":"center","roughness":1,"opacity":100},{"type":"text","id":"global_char","x":390,"y":90,"width":260,"height":60,"text":"• 여러 화면·위젯이 동시에 사용\n• 앱 실행 동안 지속\n• 상태관리 솔루션 필요","fontSize":12,"strokeColor":"#a0a0a0","fontFamily":2,"roughness":1,"opacity":100},{"type":"text","id":"global_ex","x":390,"y":155,"width":260,"height":100,"text":"예시:\n  로그인한 사용자 정보\n  장바구니 목록\n  다크모드 설정\n  알림 개수\n  언어/지역 설정","fontSize":11,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"decision","x":150,"y":280,"width":400,"height":35,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"decision_t","x":160,"y":285,"width":380,"height":25,"text":"\"다른 화면도 알아야 하는가?\" YES→Global  NO→Local","fontSize":13,"strokeColor":"#22c55e","fontFamily":2,"textAlign":"center","verticalAlign":"middle","containerId":"decision","roughness":1,"opacity":100}],"appState":{"viewBackgroundColor":"#1e1e2e"}}