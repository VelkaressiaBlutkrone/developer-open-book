{"type":"excalidraw","version":2,"source":"excalidraw-diagram-skill","elements":[{"type":"rectangle","id":"darkbg","x":-4000,"y":-3000,"width":10000,"height":7500,"backgroundColor":"#1e1e2e","fillStyle":"solid","strokeColor":"transparent","strokeWidth":0,"roughness":1,"opacity":100},{"type":"text","id":"el368","x":100,"y":10,"width":600,"height":35,"text":"TDD 사이클 (Red → Green → Refactor)","fontSize":22,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100},{"type":"rectangle","id":"el369","x":50,"y":80,"width":180,"height":60,"backgroundColor":"#5c1a1a","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el370","x":55,"y":85,"width":170,"height":50,"text":"Red\n(테스트 작성)","fontSize":16,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el369"},{"type":"text","id":"el371","x":50,"y":150,"width":180,"height":25,"text":"실패하는 테스트를 먼저 작성","fontSize":11,"strokeColor":"#ef4444","fontFamily":2,"roughness":1,"opacity":100},{"type":"arrow","id":"el372","x":230,"y":110,"width":50,"height":0,"points":[[0,0],[50,0]],"strokeColor":"#ef4444","strokeWidth":2,"endArrowhead":"arrow","roughness":1,"opacity":100},{"type":"rectangle","id":"el373","x":320,"y":80,"width":180,"height":60,"backgroundColor":"#1a4d2e","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"roughness":1,"opacity":100},{"type":"text","id":"el374","x":325,"y":85,"width":170,"height":50,"text":"Green\n(구현)","fontSize":16,"strokeColor":"#e5e5e5","fontFamily":2,"roughness":1,"opacity":100,"textAlign":"center","verticalAlign":"middle","containerId":"el373"},{"type":"text","id":"el375","x":320,"y":150,"width":180,"height":25,"text":"테스트 통과하는 최소 코드","fontSize":11,"strokeColor":"#22c55e","fontFamily":2,"roughness":1,"opacity":100},{"type":"arrow","id":"el376","x":500,"y":110,"width":50,"height":0,"points":[[0,0],[50,0]],"st